{
  "project": {
    "name": "ecs-webapp",
    "stage": "dev",
    "description": "ECS Fargate Web Application"
  },
  "stack": {
    "vpc": {
      "maxAzs": 2,
      "natGateways": 1
    },
    "logs": {
      "retentionDays": 7
    },
    "ecs": {
      "clusterName": "web-app-cluster",
      "cpu": 256,
      "memoryLimitMiB": 512,
      "desiredCount": 1,
      "containerPort": 80
    },
    "alb": {
      "port": 80
    }
  }
}
